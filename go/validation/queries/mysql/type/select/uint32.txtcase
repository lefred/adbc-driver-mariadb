// part: metadata

[setup]
drop = "test_uint32"

// part: setup_query

CREATE TABLE test_uint32 (
    idx INTEGER,
    res INT UNSIGNED
);

INSERT INTO test_uint32 (idx, res) VALUES (1, 4294967295);
INSERT INTO test_uint32 (idx, res) VALUES (2, 0);
INSERT INTO test_uint32 (idx, res) VALUES (3, 2147483648);
INSERT INTO test_uint32 (idx, res) VALUES (4, 1);
INSERT INTO test_uint32 (idx, res) VALUES (5, 2147483647);
INSERT INTO test_uint32 (idx, res) VALUES (6, NULL);

// part: query

SELECT res FROM test_uint32 ORDER BY idx

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "I",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": 4294967295}
{"res": 0}
{"res": 2147483648}
{"res": 1}
{"res": 2147483647}
{"res": null}
