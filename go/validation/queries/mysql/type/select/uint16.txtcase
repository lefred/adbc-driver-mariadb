// part: metadata

[setup]
drop = "test_uint16"

// part: setup_query

CREATE TABLE test_uint16 (
    idx INTEGER,
    res SMALLINT UNSIGNED
);

INSERT INTO test_uint16 (idx, res) VALUES (1, 65535);
INSERT INTO test_uint16 (idx, res) VALUES (2, 0);
INSERT INTO test_uint16 (idx, res) VALUES (3, 32768);
INSERT INTO test_uint16 (idx, res) VALUES (4, 1);
INSERT INTO test_uint16 (idx, res) VALUES (5, 32767);
INSERT INTO test_uint16 (idx, res) VALUES (6, NULL);

// part: query

SELECT res FROM test_uint16 ORDER BY idx

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "S",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": 65535}
{"res": 0}
{"res": 32768}
{"res": 1}
{"res": 32767}
{"res": null}
